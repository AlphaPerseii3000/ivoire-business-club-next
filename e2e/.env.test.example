# IBC Playwright E2E environment
BASE_URL=https://ivoire-business-club.com

# Required seeded accounts on the target environment
E2E_ADMIN_EMAIL=admin@ivoire-business-club.com
E2E_ADMIN_PASSWORD=change-me
E2E_AFFRANCHI_EMAIL=member-affranchi@test.com
E2E_AFFRANCHI_PASSWORD=change-me
E2E_GRANDFRERE_EMAIL=member-grandfrere@test.com
E2E_GRANDFRERE_PASSWORD=change-me
E2E_BOSS_EMAIL=member-boss@test.com
E2E_BOSS_PASSWORD=change-me

# Optional aliases / inactive subscription account
E2E_MEMBER_EMAIL=member-affranchi@test.com
E2E_MEMBER_PASSWORD=change-me
E2E_CANCELLED_EMAIL=member-cancelled@test.com
E2E_CANCELLED_PASSWORD=change-me

# Optional durable fixture records for non-mutating production checks
E2E_BOSS_OPPORTUNITY_ID=
E2E_VERIFIED_OPPORTUNITY_ID=
E2E_PENDING_OPPORTUNITY_ID=
E2E_REJECTED_OPPORTUNITY_ID=
E2E_OPPORTUNITY_WITH_DOCUMENT_ID=
E2E_PRIVATE_DOCUMENT_ID=
E2E_PENDING_SUBSCRIPTION_ID=
E2E_BOSS_SENSITIVE_TEXT=

# Mutating tests are disabled by default for production safety.
# Enable only against local/staging or when explicitly approved for idempotent production records.
E2E_ENABLE_SIGNUP_CREATE=0
E2E_CREATE_OPPORTUNITY=0
E2E_UPLOAD_DOCUMENT=0
E2E_SUBMIT_TRANSFER=0
E2E_NEW_USER_PASSWORD=E2E-Password-123!
