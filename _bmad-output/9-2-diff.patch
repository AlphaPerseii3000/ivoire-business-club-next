+        replacement = `${listPrefix}${selectedText || "Élément"}`;
+        cursorOffset = replacement.length;
+        break;
+      }
+    }
+
+    const before = text.substring(0, start);
+    const after = text.substring(end, text.length);
+    const newValue = before + replacement + after;
+
