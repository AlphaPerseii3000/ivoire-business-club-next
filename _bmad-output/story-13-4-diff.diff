+vi.mock("@/lib/auth", () => ({
+  auth: mockAuth,
+}));
+
+vi.mock("@/lib/prisma", () => ({
+  prisma: {
+    company: {
+      findMany: mockFindMany,
+    },
+  },
+}));
+
+const mockCompaniesList = [
+  {
+    id: "comp-1",
