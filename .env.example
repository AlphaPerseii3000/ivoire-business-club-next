# Cron
CRON_SECRET=

# Auth
NEXTAUTH_URL=
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAILS=berseth.j@gmail.com

# Database
# Production: PostgreSQL only, e.g. postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
# Local dev/test: SQLite is allowed, e.g. file:/absolute/path/to/prisma/dev.db
DATABASE_URL=

# Production runtime
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# App
APP_URL=

# Pop-up événement sur la landing page (affichage public). Valeur par défaut : false.
NEXT_PUBLIC_SHOW_EVENT_POPUP=false

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2 (document storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Resend (emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Infomaniak Email sending (SMTP) - legacy, kept for reference but no longer used by the app
# MAIL_MAILER=
# MAIL_HOST=
# MAIL_PORT=
# MAIL_ENCRYPTION=
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=
# MAIL_FROM_NAME=

# Bank transfer (payment details)
BANK_TRANSFER_IBAN=
BANK_TRANSFER_BIC=
BANK_TRANSFER_BANK_ADDRESS=

# Support
SUPPORT_WHATSAPP_NUMBER=

# Media storage (VPS local path for event cover uploads)
# Dev/test default: ./public/ibc-media (relative to project root)
# Production: /var/www/ibc-media (must exist with write permissions for the Node.js process)
MEDIA_STORAGE_PATH=./public/ibc-media

# Webhook Temps Réel (Hermes)
# URL publique du webhook Hermes, exposée via tunnel Cloudflare (port 8644 en local).
# Exemple : https://ibc-chat-trigger-123.trycloudflare.com/webhook/ibc-chat-trigger
# Si non définie, l'appel webhook est silencieusement ignoré.
WEBHOOK_URL=
# Secret HMAC-SHA256 pour signer les appels webhook vers Hermes (header X-Webhook-Signature).
# Différent de CRON_SECRET.
WEBHOOK_SECRET=

# Adhesion contract URL (optional, included in welcome email if set)
ADHESION_CONTRACT_URL=

# Infomaniak Swiss Backup Storage (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
